     See http://www.gnu.org/licenses/ for a copy of the license text -->
  <os id="http://suse.com/sles/16-unknown">
    <short-id>sles16-unknown</short-id>
    <name>SUSE Linux Enterprise Server 16 Unknown</name>
    <version>16-unknown</version>
    <vendor>SUSE</vendor>
    <family>linux</family>
    <distro>sles</distro>
    <upgrades id="http://suse.com/sles/16.0"/>
    <derives-from id="http://suse.com/sles/16.0"/>

    <media arch="x86_64">
      <iso>
        <system-id>LINUX</system-id>
        <volume-id>Install-SUSE-SLE-16.[1-9]-x86_64</volume-id>
      </iso>
      <kernel>boot/x86_64/loader/linux</kernel>
      <initrd>boot/x86_64/loader/initrd</initrd>
    </media>

    <media arch="aarch64">
      <iso>
        <system-id>LINUX</system-id>
        <volume-id>Install-SUSE-SLE-16.[1-9]-aarch64</volume-id>
      </iso>
      <kernel>boot/aarch64/loader/linux</kernel>
      <initrd>boot/aarch64/loader/initrd</initrd>
    </media>

    <media arch="ppc64">
      <iso>
        <system-id>LINUX</system-id>
        <volume-id>Install-SUSE-SLE-16.[1-9]-ppc64le</volume-id>
      </iso>
      <kernel>boot/ppc64le/loader/linux</kernel>
      <initrd>boot/ppc64le/loader/initrd</initrd>
    </media>

    <media arch="s390x">
      <iso>
        <system-id>LINUX</system-id>
        <volume-id>Install-SUSE-SLE-16.[1-9]-s390x</volume-id>
      </iso>
      <kernel>boot/s390x/loader/linux</kernel>
      <initrd>boot/s390x/loader/initrd</initrd>
    </media>

    <resources arch="all">
      <minimum>
        <cpu>500000000</cpu>
        <ram>1073741824</ram>
        <storage>2147483648</storage>
      </minimum>
      <recommended>
        <cpu>2400000000</cpu>
        <n-cpus>2</n-cpus>
        <ram>4294967296</ram>
        <storage>34359738368</storage>
      </recommended>
    </resources>
  </os>
</libosinfo>
